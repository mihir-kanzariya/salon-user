# ============================================
# Saloon Flutter App - Environment Configuration
# ============================================
# These values are passed via --dart-define when running the app.
#
# Option 1 — Inline flags:
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:3000/api/v1 \
#     --dart-define=SUPABASE_URL=https://your-project.supabase.co \
#     --dart-define=SUPABASE_ANON_KEY=your_supabase_anon_key
#
# Option 2 — From file (copy this file to .env and edit):
#   flutter run --dart-define-from-file=.env

# ---------- Backend API ----------
# Android emulator:  http://10.0.2.2:3000/api/v1
# iOS simulator:     http://localhost:3000/api/v1
# Physical device:   http://192.168.x.x:3000/api/v1 (your machine's LAN IP)
# Used in: lib/config/api_config.dart
API_BASE_URL=http://localhost:3000/api/v1

# ---------- Supabase (Realtime Chat) ----------
# Get these from: Supabase Dashboard → Settings → API
# Used in: lib/main.dart (SupabaseChatService init)
# Optional — chat works via REST without these, just not real-time
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------- Notes ----------
# Razorpay key: Sent from the backend API response, NOT a Flutter env var.
# Firebase:     Configured via google-services.json (Android) and
#               GoogleService-Info.plist (iOS), not via env vars.
#               See: https://firebase.google.com/docs/flutter/setup
